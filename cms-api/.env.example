# Copy to `.env` and fill in real values. Never commit the real .env.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=admin
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=cms

# Server port (dev default 3021; Docker uses 3022)
PORT=3021

# Origin allowed by CORS (the web app)
CORS_ORIGIN=http://localhost:3000

# REQUIRED — server refuses to start if missing/<16 chars.
# generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES=12h
