# Copy to `.env` (same folder as docker-compose.yml) and adjust.
# docker compose reads this file automatically for ${VAR} substitution.

# ---- ports (host side) ----
WEB_PORT=3021
API_PORT=3022

# ---- existing database (the API connects to this; it is NOT created by compose) ----
# host.docker.internal = your MySQL published on the host (e.g. the form_db container on :3306)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=cms
MYSQL_USER=admin
MYSQL_PASSWORD=123456

# Leave false so an existing DB is never reset. Set true only for a brand-new empty DB.
AUTO_SEED=false

# ---- secrets — CHANGE THESE IN PRODUCTION ----
# generate: openssl rand -base64 48
JWT_SECRET=dev-compose-jwt-secret-change-me-please
NEXTAUTH_SECRET=dev-compose-nextauth-secret-change-me
