# Copy to `.env` (same folder as docker-compose.yml) and adjust.
# docker compose reads this file automatically for ${VAR} substitution.

# ---- host ports the reverse proxy points at ----
WEB_PORT=3021
API_PORT=3022

# ---- public URLs (behind your reverse proxy) ----
# Local dev — leave commented (defaults to http://localhost:3021 / :3022).
# Production example (single domain, proxy routes /api → api):
#   PUBLIC_WEB_URL=https://data.lifesystemd.com
#   PUBLIC_API_URL=https://data.lifesystemd.com/api
# Production example (API on a subdomain):
#   PUBLIC_WEB_URL=https://data.lifesystemd.com
#   PUBLIC_API_URL=https://api.data.lifesystemd.com/api
PUBLIC_WEB_URL=http://localhost:3021
PUBLIC_API_URL=http://localhost:3022/api

# ---- existing database (the API connects to this; it is NOT created by compose) ----
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=cms
MYSQL_USER=admin
MYSQL_PASSWORD=change-me

# Leave false so an existing DB is never reset. Set true only for a brand-new empty DB.
AUTO_SEED=false

# ---- secrets — REQUIRED in production ----
# generate: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-min-16
NEXTAUTH_SECRET=change-me-to-a-long-random-string
